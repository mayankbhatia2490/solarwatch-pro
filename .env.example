# ── Site Identity ──────────────────────────────────────────────────────────────
# Unique ID for this installation — written as a tag on every InfluxDB point.
# For B2B multi-tenant: set a different SITE_ID on each collector deployment
# and query with header: X-Site-ID: <site_id>
SITE_ID=mayank-karnal-001
LOCATION_NAME=Karnal, Haryana

# ── ShineMonitor API ───────────────────────────────────────────────────────────
SHINEMONITOR_USERNAME=
SHINEMONITOR_PASSWORD=
SHINEMONITOR_COMPANY_KEY=
SHINEMONITOR_PLANT_ID=
SHINEMONITOR_PN=
SHINEMONITOR_SN=
SHINEMONITOR_DEVCODE=1

# ── System Specifications ──────────────────────────────────────────────────────
# Inverter: KSY 3.4KW-1Ph (single-phase, 1 MPPT)
# Panels:  6 × Vikram Solar HyperSol VSMDH.72.595.05
#          N-type bifacial, M10 half-cut, 144 cells, 23.03% efficiency
#          STC: 595W | BNPI: 659W | γ(Pmax): -0.30%/°C | NOCT: 45°C
#          Source: Vikram Solar datasheet VSL/ENG/SC/325-V02/STD
INSTALLED_CAPACITY_W=3570
INSTALLATION_DATE=2025-04-17
SYSTEM_COST_INR=190000
LATITUDE=29.693405600010355
LONGITUDE=76.99938211551195
TIMEZONE=Asia/Kolkata
PLANT_NAME=My Solar System

# ── UHBVN Tariff Configuration ─────────────────────────────────────────────────
# Update these from your latest electricity bill when HERC issues new orders.
# Current: FY 2025-26 domestic (DS) rates — verify at https://www.uhbvn.org.in/tariff
ELECTRICITY_DISTRIBUTOR=UHBVN
TARIFF_YEAR=2025-26
TARIFF_SLAB1_LIMIT=100
TARIFF_SLAB1_RATE=2.50
TARIFF_SLAB2_LIMIT=300
TARIFF_SLAB2_RATE=5.25
TARIFF_SLAB3_LIMIT=500
TARIFF_SLAB3_RATE=6.50
TARIFF_SLAB4_RATE=7.00
TARIFF_FUEL_SURCHARGE_PER_UNIT=0.35
TARIFF_ELECTRICITY_DUTY_PCT=5.0
TARIFF_METER_RENT_INR=30.0
# Simple flat rate used for interval-level loss calculations
ELECTRICITY_TARIFF_INR=6.50

# ── InfluxDB ───────────────────────────────────────────────────────────────────
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=my-super-secret-auth-token-replace-me
INFLUXDB_ORG=solar
INFLUXDB_BUCKET=solar_metrics

# ── AI (Gemini) ────────────────────────────────────────────────────────────────
# Free tier: https://aistudio.google.com/app/apikey
# Used for: 2-sentence daily performance insight in Telegram report (1 call/day)
# Leave blank to disable — report still sends without AI analysis
GEMINI_API_KEY=

# ── Consumption baseline ───────────────────────────────────────────────────────
# Where to find this on your UHBVN bill:
#   Look for "Units Consumed" or "Net Units" on the bill (the kWh number).
#   Use the average of 2-3 summer months (May/Jun/Jul) for a conservative baseline.
#   If you don't know yet, leave 600 — it's a reasonable Haryana household default.
#   Update this any time with: nano /volume1/docker/solarwatch-pro/.env
#   Then restart the API: docker compose restart solar-api
MONTHLY_CONSUMPTION_KWH=600

# ── Telegram Notifications ─────────────────────────────────────────────────────
# Create a bot via @BotFather → /newbot, then /start your bot, then check
# GET /api/notifications/chat-id to auto-detect your chat ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Email Alerts ───────────────────────────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=

# ── Grafana ────────────────────────────────────────────────────────────────────
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=changeme

# ── Frontend ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8090
NODE_ENV=development

# ── Docker volumes (Synology NAS example paths) ───────────────────────────────
# DATA_PATH=/volume1/docker/solarwatch/data
# Uncomment and set DATA_PATH in docker-compose.prod.yml for persistent storage
